@Qams.Training.Api_HostAddress = http://localhost:5165

GET {{Qams.Training.Api_HostAddress}}/health
Accept: application/json

###

GET {{Qams.Training.Api_HostAddress}}/api/v1/training-courses
Accept: application/json

###

POST {{Qams.Training.Api_HostAddress}}/api/v1/training-courses
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Idempotency-Key: create-training-course-001

{
  "tenantId": "tenant-life-sciences-demo",
  "title": "Good Manufacturing Practices",
  "description": "Training on GMP requirements for manufacturing operations.",
  "durationMinutes": 120,
  "required": true
}

###

POST {{Qams.Training.Api_HostAddress}}/api/v1/training-courses/{courseId}/enroll
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Idempotency-Key: enroll-training-001

{
  "tenantId": "tenant-life-sciences-demo",
  "traineeUserId": "qa-technician-1"
}

###

POST {{Qams.Training.Api_HostAddress}}/api/v1/training-courses/{courseId}/enrollments/{enrollmentId}/complete
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Idempotency-Key: complete-training-001

{
  "tenantId": "tenant-life-sciences-demo",
  "completedByUserId": "qa-technician-1",
  "score": 95
}
