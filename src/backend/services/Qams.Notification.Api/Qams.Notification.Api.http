@Qams.Notification.Api_HostAddress = http://localhost:5057

GET {{Qams.Notification.Api_HostAddress}}/health
Accept: application/json

###

GET {{Qams.Notification.Api_HostAddress}}/api/v1/notifications
Accept: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Correlation-Id: 00000000-0000-0000-0000-000000000001

###

POST {{Qams.Notification.Api_HostAddress}}/api/v1/notifications
Accept: application/json
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Correlation-Id: 00000000-0000-0000-0000-000000000002
Idempotency-Key: demo-notification-001

{
  "tenantId": "tenant-life-sciences-demo",
  "recipientUserId": "qa-manager-demo",
  "subject": "CAPA action required",
  "message": "Your CAPA follow-up actions require approval."
}

###

POST {{Qams.Notification.Api_HostAddress}}/api/v1/notifications/email
Accept: application/json
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Correlation-Id: 00000000-0000-0000-0000-000000000003
Idempotency-Key: demo-email-notification-001

{
  "tenantId": "tenant-life-sciences-demo",
  "recipientUserId": "qa-manager-demo",
  "emailAddress": "asha.patel@example.com",
  "subject": "CAPA closure approved",
  "message": "The CAPA case has been approved and closed."
}

###

POST {{Qams.Notification.Api_HostAddress}}/api/v1/notifications/{{notificationId}}/acknowledge
Accept: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Correlation-Id: 00000000-0000-0000-0000-000000000004

