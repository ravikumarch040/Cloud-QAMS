@Qams.Complaints.Api_HostAddress = http://localhost:5172

GET {{Qams.Complaints.Api_HostAddress}}/health
Accept: application/json

###

GET {{Qams.Complaints.Api_HostAddress}}/api/v1/complaints
Accept: application/json

###

POST {{Qams.Complaints.Api_HostAddress}}/api/v1/complaints
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Idempotency-Key: create-complaint-001

{
  "tenantId": "tenant-life-sciences-demo",
  "complaintType": "Supplier Issue",
  "description": "Received material with inconsistent batch labels.",
  "reportedByUserId": "qa-inspector",
  "reportedAtUtc": "2026-05-03T10:00:00Z"
}

###

POST {{Qams.Complaints.Api_HostAddress}}/api/v1/complaints/comp-0001/resolve
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Idempotency-Key: resolve-complaint-001

{
  "tenantId": "tenant-life-sciences-demo",
  "resolvedByUserId": "complaints-manager",
  "resolutionNotes": "Material returned to supplier and corrective action initiated."
}
