@Qams.ValidationEvidence.Api_HostAddress = http://localhost:5169

GET {{Qams.ValidationEvidence.Api_HostAddress}}/health
Accept: application/json

###

GET {{Qams.ValidationEvidence.Api_HostAddress}}/api/v1/validation-evidence
Accept: application/json

###

POST {{Qams.ValidationEvidence.Api_HostAddress}}/api/v1/validation-evidence
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Idempotency-Key: create-123

{
  "tenantId": "tenant-life-sciences-demo",
  "title": "Release Validation Evidence",
  "description": "Validation evidence pack for software release.",
  "relatedRequirementIds": ["REQ-450", "REQ-451"],
  "evidenceItems": [
    { "itemId": "item-1", "name": "Verification Protocol", "description": "Protocol document." },
    { "itemId": "item-2", "name": "Test Summary", "description": "Summary report." }
  ]
}

###

POST {{Qams.ValidationEvidence.Api_HostAddress}}/api/v1/validation-evidence/pack-demo-001/approve
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Idempotency-Key: approve-123

{
  "tenantId": "tenant-life-sciences-demo",
  "approvedByUserId": "qa-manager",
  "approvalComments": "Evidence pack meets release criteria."
}
