@Qams.DocumentControl.Api_HostAddress = http://localhost:5170

GET {{Qams.DocumentControl.Api_HostAddress}}/health
Accept: application/json

###

GET {{Qams.DocumentControl.Api_HostAddress}}/api/v1/documents
Accept: application/json

###

POST {{Qams.DocumentControl.Api_HostAddress}}/api/v1/documents
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Idempotency-Key: create-doc-001

{
  "tenantId": "tenant-life-sciences-demo",
  "title": "Controlled Document: Calibration Procedure",
  "description": "Procedure for calibration of lab equipment.",
  "initialVersions": [
    { "versionLabel": "v1.0", "changeDescription": "Initial document draft", "contentHash": "f00dbabe1234" }
  ]
}

###

POST {{Qams.DocumentControl.Api_HostAddress}}/api/v1/documents/doc-001/versions
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Idempotency-Key: add-version-001

{
  "tenantId": "tenant-life-sciences-demo",
  "versionLabel": "v1.1",
  "changeDescription": "Updated effective date and review comments.",
  "contentHash": "cafebabedeadbeef"
}

###

POST {{Qams.DocumentControl.Api_HostAddress}}/api/v1/documents/doc-001/approve
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Idempotency-Key: approve-doc-001

{
  "tenantId": "tenant-life-sciences-demo",
  "approvedByUserId": "doc-control-manager",
  "approvalComments": "Document approved for controlled release."
}
