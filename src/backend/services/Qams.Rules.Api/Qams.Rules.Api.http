@Qams.Rules.Api_HostAddress = http://localhost:5129

GET {{Qams.Rules.Api_HostAddress}}/health
Accept: application/json

###

GET {{Qams.Rules.Api_HostAddress}}/api/v1/rules
Accept: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Correlation-Id: 00000000-0000-0000-0000-000000000001

###

POST {{Qams.Rules.Api_HostAddress}}/api/v1/rules/evaluate
Accept: application/json
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Correlation-Id: 00000000-0000-0000-0000-000000000002

{
  "tenantId": "tenant-life-sciences-demo",
  "resourceType": "CapaCase",
  "action": "close",
  "userRoles": ["qa-manager"],
  "attributes": {}
}

###

POST {{Qams.Rules.Api_HostAddress}}/api/v1/rules/trigger
Accept: application/json
Content-Type: application/json
X-Tenant-Id: tenant-life-sciences-demo
X-Correlation-Id: 00000000-0000-0000-0000-000000000003
Idempotency-Key: demo-rule-trigger-001

{
  "tenantId": "tenant-life-sciences-demo",
  "resourceType": "CAPA Case",
  "triggerEvent": "CapaClosed",
  "payload": {
    "capaCaseId": "capa-0001"
  }
}

